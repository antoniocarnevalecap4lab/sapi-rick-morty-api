			<set-variable value="#[500]" doc:name="Set the HTTP Status - 500" doc:id="d11d62a2-5ff9-4ff4-bdda-0aae7e17bbed" variableName="httpStatus" />
      			<set-variable value="INTERNAL_SERVER_ERROR" doc:name="Set Error Code" doc:id="e31a327e-2c0f-4790-b3d1-80999add4d51" variableName="errorCode" />
			<flow-ref doc:name="global-prepare-error-response-sub-flow" doc:id="24f1c0b7-9da8-4c7c-849b-4bd5fe5b4a9e" name="global-prepare-error-response-sub-flow"/>
		</on-error-continue>
		
		<!-- Generic CONNECTIVITY Related Exception handling start. Order matters -->
		<on-error-continue type="RETRY_EXHAUSTED" enableNotifications="true" logException="true" doc:name="On Error Continue" doc:id="a9c150cb-7599-4fff-a12a-99e0209507f7" >
			<set-variable value="#[503]" doc:name="Set the HTTP Status - 503" doc:id="d3869ed0-77c1-4828-aa18-e4f12a5271cd" variableName="httpStatus" />
      			<set-variable value="SERVICE_UNAVAILABLE" doc:name="Set Error Code" doc:id="40b4bb95-2d92-48e8-a5e7-97f56cf00eb9" variableName="errorCode" />
			<flow-ref doc:name="global-prepare-error-response-sub-flow" doc:id="4f29a83f-bddd-4675-9c4d-19b7c415ad05" name="global-prepare-error-response-sub-flow"/>
		</on-error-continue>
		<on-error-continue type="REDELIVERY_EXHAUSTED" enableNotifications="true" logException="true" doc:name="On Error Continue" doc:id="9d5ff418-689c-4679-a845-31379ee991dd" >
			<set-variable value="#[503]" doc:name="Set the HTTP Status - 503" doc:id="63f27a25-e5cc-4c0b-828e-a75287e40659" variableName="httpStatus" />
      			<set-variable value="SERVICE_UNAVAILABLE" doc:name="Set Error Code" doc:id="745f8828-bca5-4707-ad62-5a130dd51e9e" variableName="errorCode" />
			<flow-ref doc:name="global-prepare-error-response-sub-flow" doc:id="714fee56-d7f5-467f-8832-44c82f34191d" name="global-prepare-error-response-sub-flow"/>
		</on-error-continue>
		<on-error-continue type="CONNECTIVITY" enableNotifications="true" logException="true" doc:name="On Error Continue" doc:id="73437c43-21eb-48a0-84dd-6136104cd870" >
			<set-variable value="#[503]" doc:name="Set the HTTP Status - 503" doc:id="6df012a7-38ea-49f8-9051-4c0271b21dae" variableName="httpStatus" />
      			<set-variable value="SERVICE_UNAVAILABLE" doc:name="Set Error Code" doc:id="d2324f04-21ae-4a46-b663-7c729e02f252" variableName="errorCode" />
