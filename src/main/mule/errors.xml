		</on-error-continue>
		<on-error-continue type="TIMEOUT" enableNotifications="true" logException="true" doc:name="On Error Continue" doc:id="a479704d-8157-4679-8acd-4705cf902b3e" >
			<set-variable value="#[504]" doc:name="Set the HTTP Status - 504" doc:id="d24e1c3b-16a3-45cc-b75d-fd1bed1cd69b" variableName="httpStatus" />
      			<set-variable value="GATEWAY_TIMEOUT" doc:name="Set Error Code" doc:id="e482b4a5-9e1e-4660-930a-5d505642c5af" variableName="errorCode" />
			<flow-ref doc:name="global-prepare-error-response-sub-flow" doc:id="d1c89ef9-c150-4010-984c-c2260dd41c0f" name="global-prepare-error-response-sub-flow"/>
		</on-error-continue>
		<!-- Generic CONNECTIVITY Exception handling end -->
		
		<on-error-continue type="TRANSFORMATION" enableNotifications="true" logException="true" doc:name="On Error Continue" doc:id="c1a4598c-2d51-46bf-9ae8-8d166971057c" >
			<set-variable value="#[400]" doc:name="Set the HTTP Status - 400" doc:id="4221214a-711c-43bf-b3d4-1ba73d646d22" variableName="httpStatus" />
      			<set-variable value="BAD_REQUEST" doc:name="Set Error Code" doc:id="6435b8b3-d29b-4d1c-898f-dc7c5833d959" variableName="errorCode" />
			<flow-ref doc:name="global-prepare-error-response-sub-flow" doc:id="c0e40d33-6ff2-4f9e-884b-1221d5247211" name="global-prepare-error-response-sub-flow"/>
		</on-error-continue>
		
		<on-error-continue type="EXPRESSION" enableNotifications="true" logException="true" doc:name="On Error Continue" doc:id="8d75775b-67c8-4bab-9571-ef014b38e257" >
			<set-variable value="#[500]" doc:name="Set the HTTP Status - 500" doc:id="28fb593b-a282-47b2-b8f9-36406ce410d3" variableName="httpStatus" />
			<set-variable value="INTERNAL_SERVER_ERROR" doc:name="Set Error Code" doc:id="1dea7d89-1630-481e-8df7-ad6e9adaf355" variableName="errorCode" />
			<flow-ref doc:name="global-prepare-error-response-sub-flow" doc:id="51017a1e-882a-40b2-b803-ae870972b8d7" name="global-prepare-error-response-sub-flow"/>
		</on-error-continue>	
		<on-error-continue type="ROUTING" enableNotifications="true" logException="true" doc:name="On Error Continue" doc:id="db28359a-0778-4f3e-9448-0619684f7e78" >
			<set-variable value="#[400]" doc:name="Set the HTTP Status - 400" doc:id="216d7e56-71db-41fb-9679-97db925823f6" variableName="httpStatus" />
      			<set-variable value="BAD_REQUEST" doc:name="Set Error Code" doc:id="4d3d8382-194d-4b00-aab3-e49ebca11642" variableName="errorCode" />
			<flow-ref doc:name="global-prepare-error-response-sub-flow" doc:id="fbea5169-62a7-47be-abe2-eb34cd1e81c1" name="global-prepare-error-response-sub-flow"/>
		</on-error-continue>
		<on-error-continue type="SECURITY" enableNotifications="true" logException="true" doc:name="On Error Continue" doc:id="990518e6-1350-4b0f-a06c-c7a3831f5af2" >
			<set-variable value="#[401]" doc:name="Set the HTTP Status - 401" doc:id="b5495501-e8ba-4eea-b278-1e26e256bbf2" variableName="httpStatus" />
      			<set-variable value="UNAUTHORIZED" doc:name="Set Error Code" doc:id="5c41c8ce-eeb9-46fc-acba-c18d335ff121" variableName="errorCode" />
			<flow-ref doc:name="global-prepare-error-response-sub-flow" doc:id="92bd104c-d952-4d1c-b94f-d2df3196d829" name="global-prepare-error-response-sub-flow"/>
		</on-error-continue>
		
		
		<!-- If none of the above matches then handle a the exception using generic handler -->
		<on-error-continue type="ANY" enableNotifications="true" logException="true" doc:name="On Error Continue" doc:id="6b773823-7530-49b7-8570-3fa87f6fcea5">
			<set-variable value="#[500]" doc:name="Set HTTP Status - 500" variableName="httpStatus"/>
			<set-variable value="INTERNAL_SERVER_ERROR" doc:name="Set Error Code" doc:id="c41a9eee-eee5-4472-82cd-a573478a58b8" variableName="errorCode" />
			<set-variable value="Unable to fullfil request due to internal error." doc:name="Set Error Meesage" doc:id="4266487b-9b2c-4817-92cc-a7d666ef0d9d" variableName="errorMessage"/>
			<flow-ref doc:name="global-prepare-error-response-sub-flow" doc:id="2ec0af1b-96cc-4e13-8f4c-5172efeb6257" name="global-prepare-error-response-sub-flow"/>
		</on-error-continue>
		
	</error-handler>
	<sub-flow name="global-prepare-error-response-sub-flow" doc:id="6eec9f1a-def4-4df4-a4ab-cf190c7cd8be">
		<logger level="ERROR" doc:name="Logger" doc:id="83b23171-74df-4310-82fc-b7fe39962b11" message="Status Code [#[vars.httpStatus]] - Error Code [#[vars.errorCode]] - Error Message [#[if(vars.errorMessage != null) vars.errorMessage else '']] - Error Description [#[if(vars.errorDescription != null) vars.errorDescription else '']]" />
		<ee:transform doc:name="Compose Error Payload" doc:id="8d35b8c3-6952-4bc1-b7da-22ac3dda3ce7">
			<ee:message>
				<ee:set-payload><![CDATA[%dw 2.0
output application/json
---

{
  "result": {
    "code": vars.httpStatus as String ,
    "description": error.errorMessage.payload default error.description
  },
  "response": {}
}]]></ee:set-payload>
			</ee:message>
		</ee:transform>
    </sub-flow>
</mule>
