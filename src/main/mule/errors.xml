			<flow-ref doc:name="global-prepare-error-response-sub-flow" doc:id="fb510c30-bc00-4f50-9195-bf5475ad4d05" name="global-prepare-error-response-sub-flow"/>
		</on-error-continue>
		<on-error-continue type="HTTP:PARSING" enableNotifications="true" logException="true" doc:name="On Error Continue" doc:id="dcabc2cf-378b-44b6-bb5a-128ceaa6f846" >
			<set-variable value="#[400]" doc:name="Set the HTTP Status - 400" doc:id="9b9a2b44-5e05-4dc0-9c7a-f01fb951f500" variableName="httpStatus" />
