      <set-variable value="SERVICE_UNAVAILABLE" doc:name="Set Error Code" doc:id="830df94f-bcb8-4731-a6af-0a37d9bb9eac" variableName="errorCode" />
			<flow-ref doc:name="global-prepare-error-response-sub-flow" doc:id="3bde2940-fb9a-4cff-8470-506a9488b736" name="global-prepare-error-response-sub-flow"/>
		</on-error-continue>
		<on-error-continue type="HTTP:SECURITY" enableNotifications="true" logException="true" doc:name="On Error Continue" doc:id="4f7e8b7b-499c-4bce-b838-29c3ba75a700" >
